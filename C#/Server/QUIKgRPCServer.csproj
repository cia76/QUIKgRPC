<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyVersion>1.0.0</AssemblyVersion>
  </PropertyGroup>
  <ItemGroup>
	<Protobuf Include="../../protos/structures.proto" GrpcServices="Server" ProtoRoot="../../protos/" />
  <Protobuf Include="../../protos/service.proto" GrpcServices="Server" ProtoRoot="../../protos/" />
	<Protobuf Include="../../protos/interaction.proto" GrpcServices="Server" ProtoRoot="../../protos/" />
	<Protobuf Include="../../protos/callback.proto" GrpcServices="Server" ProtoRoot="../../protos/" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore" Version="2.63.0" />
    <PackageReference Include="System.Net.Sockets" Version="4.3.0" />
  </ItemGroup>
</Project>
