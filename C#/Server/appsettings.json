{
  "ApplicationSettings": {
    "Host": "localhost",
    "RequestsPort": 34130,
    "CallbacksPort": 34131
  },
  "Logging": {
    "LogLevel": {
      "QUIKgRPCServer": "Debug", // Сервер gRPC
      "QuikGrpc.Services": "Debug", // Сервисы
      "Grpc.AspNetCore.Server": "Warning",
      "Default": "Information", // Остальные библиотеки
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting": "Information",
      "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  }
}
